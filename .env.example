# NorsNite — required environment variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase (get from: supabase.com → project → Settings → API) ─────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Admin (Supabase auth.users UUID of the admin account) ────────────────────
# Log in once, then find your UUID in: supabase.com → Authentication → Users
VITE_ADMIN_USER_ID=your-uuid-here

# ── For production (set in Cloudflare Pages → Settings → Environment variables)
# Same three keys above, but with real prod Supabase project values.
